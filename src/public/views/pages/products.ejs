<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Productos' , cssFile: 'products.css' }) %>

    <body>
        <div class="layout">
            <%- include('../partials/sidebar', { activePage: 'products' }) %>

                <main class="layout__content">
                    <%- include('../partials/navbar', { title: 'Productos' }) %>
                        <script src="/js/products.js" defer></script>


                        <div class="main-container">
                            <div class="products-toolbar">
                                <div class="toolbar-left">
                                    <div class="search-bar">
                                        <span class="material-symbols-outlined search-icon">search</span>
                                        <input type="text" id="product-search"
                                            placeholder="Buscar por nombre o código..."
                                            onkeypress="if(event.key === 'Enter') applyFilters()">
                                    </div>

                                    <div class="filter-wrapper" id="filter-wrapper">
                                        <button class="btn-filter" id="btn-filter-toggle">
                                            <span class="material-symbols-outlined">filter_list</span> Filtros
                                        </button>

                                        <div class="filter-menu" id="filter-menu">
                                            <header class="modal-header">
                                                <h3>Filtros</h3>
                                                <button class="btn-close-modal" data-target="filter-wrapper">
                                                    <span class="material-symbols-outlined">close</span>
                                                </button>
                                            </header>
                                            <div class="filter-group">
                                                <label>Categoría</label>
                                                <select id="filter-category">
                                                    <option value="">Todas</option>
                                                </select>
                                            </div>
                                            <div class="filter-group">
                                                <label>Estado</label>
                                                <div class="radio-group">
                                                    <label><input type="radio" name="filter-status" value="true"
                                                            checked> Activos</label>
                                                    <label><input type="radio" name="filter-status" value="false">
                                                        Papelera</label>
                                                </div>
                                            </div>
                                            <button class="btn-apply" onclick="applyFilters()">Aplicar Filtros</button>
                                        </div>
                                    </div>
                                </div>

                                <div class="toolbar-right">
                                    <button class="btn-secondary" id="btn-open-categories">
                                        <span class="material-symbols-outlined">category</span> Categorías
                                    </button>
                                    <button class="btn-primary" id="btn-open-add" onclick="openProductModal()">
                                        <span class="material-symbols-outlined">add</span> Nuevo Producto
                                    </button>
                                </div>
                            </div>

                            <div class="product-grid" id="product-grid">
                                <div class="loading-state" style="grid-column: 1 / -1;">
                                    <span class="material-symbols-outlined spin">refresh</span>
                                    Cargando catálogo...
                                </div>
                            </div>

                            <footer class="pagination-footer">
                                <button class="btn-page" id="btn-prev-page" onclick="changePage(-1)" disabled><span
                                        class="material-symbols-outlined">chevron_left</span></button>
                                <span class="page-info" id="page-info">Página 1</span>
                                <button class="btn-page" id="btn-next-page" onclick="changePage(1)"><span
                                        class="material-symbols-outlined">chevron_right</span></button>
                            </footer>
                        </div>

                        <div class="modal-overlay" id="modal-add-product">
                            <div class="modal-card">
                                <header class="modal-header">
                                    <h3 id="product-modal-title">Añade un producto</h3>
                                    <button class="btn-close-modal" data-target="modal-add-product">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </header>

                                <form class="modal-form" id="form-product">
                                    <input type="hidden" id="prod-id">
                                    <input type="hidden" id="prod-is-active" value="1">

                                    <div class="modal-form-grid">
                                        <!-- Columna Izquierda: Inputs de Texto -->
                                        <div class="modal-text-col">
                                            <div class="form-group">
                                                <label>Nombre del Producto</label>
                                                <input type="text" id="prod-name" placeholder="Ej: Coca Cola 2.25L" required>
                                            </div>

                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label>Código de Barras</label>
                                                    <input type="text" id="prod-code" placeholder="Ej: 779123456789" required>
                                                </div>
                                                <div class="form-group">
                                                    <label>Categoría</label>
                                                    <select id="prod-category" required>
                                                        <option value="" disabled selected>Seleccionar...</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <label>Descripción</label>
                                                <textarea id="prod-desc" rows="4" placeholder="Detalles del producto..." required></textarea>
                                            </div>
                                        </div>

                                        <!-- Columna Derecha: Imagen -->
                                        <div class="modal-image-col">
                                            <div>
                                                <label>Imagen Actual / Vista Previa</label>
                                                <div class="preview-img-container">
                                                    <img id="prod-img-preview" src="" alt="Producto">
                                                </div>
                                            </div>
                                            
                                            <div>
                                                <label>Cambiar Imagen</label>
                                                <input type="file" id="prod-img" name="image" accept="image/*">
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="modal-actions">
                                        <button type="button" class="btn-cancel"
                                            data-target="modal-add-product">Cancelar</button>
                                        <button type="submit" class="btn-confirm" id="btn-save-product">Guardar
                                            Producto</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="modal-overlay" id="modal-manage-categories">
                            <div class="modal-card modal-medium">
                                <header class="modal-header">
                                    <h3>Administrar Categorías</h3>
                                    <button class="btn-close-modal" data-target="modal-manage-categories">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </header>

                                <div class="categories-manager">
                                    <form class="add-category-row" id="form-category">
                                        <input type="text" id="new-category-name" placeholder="Nueva categoría..."
                                            required>
                                        <button type="submit" class="btn-mini-add">
                                            <span class="material-symbols-outlined">add</span>
                                        </button>
                                    </form>
                                    <ul class="categories-list" id="categories-list-container">
                                    </ul>
                                </div>
                            </div>
                        </div>

                </main>
        </div>

    </body>

</html>