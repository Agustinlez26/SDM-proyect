<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Usuarios' , cssFile: 'users.css' }) %>

    <body>
        <div class="layout">
            <%- include('../partials/sidebar', { activePage: 'users' }) %>

                <main class="layout__content">
                    <%- include('../partials/navbar', { title: 'Usuarios' }) %>
                        <script src="/js/users.js" defer></script>

                        <div class="main-container">

                            <div class="users-toolbar">
                                <div class="search-bar">
                                    <span class="material-symbols-outlined search-icon">search</span>
                                    <input type="text" id="user-search" placeholder="Buscar por nombre o ID..."
                                        onkeypress="if(event.key === 'Enter') applyFilters()">
                                </div>

                                <div class="filter-wrapper" id="filter-wrapper">
                                    <button class="btn-filter" id="btn-filter-toggle">
                                        <span class="material-symbols-outlined">filter_list</span> Filtros
                                    </button>
                                    <div class="filter-menu" id="filter-menu">
                                        <header class="modal-header">
                                            <h3>Filtros</h3>
                                            <button class="btn-close-modal" id="btn-close-filter"
                                                data-target="filter-wrapper">
                                                <span class="material-symbols-outlined">close</span>
                                            </button>
                                        </header>
                                        <div class="filter-group">
                                            <label>Estado</label>
                                            <select id="filter-status">
                                                <option value="">Todos</option>
                                                <option value="true" selected>Activos</option>
                                                <option value="false">Inactivos</option>
                                            </select>
                                        </div>
                                        <div class="filter-group">
                                            <label>Rol</label>
                                            <select id="filter-role">
                                                <option value="">Cualquier Rol</option>
                                                <option value="true">Administrador</option>
                                                <option value="false">Empleado</option>
                                            </select>
                                        </div>
                                        <div class="filter-actions">
                                            <button class="btn-cancel" onclick="clearFilters()"
                                                style="margin-right: 10px;">Limpiar</button>
                                            <button class="btn-apply" onclick="applyFilters()">Aplicar Filtros</button>
                                        </div>
                                    </div>
                                </div>

                                <button class="btn-primary" onclick="abrirModalNuevoUsuario()">
                                    <span class="material-symbols-outlined">person_add</span> Nuevo Empleado
                                </button>
                            </div>

                            <div class="users-grid" id="users-list-container">
                                <div class="loading-state"
                                    style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                                    <span class="material-symbols-outlined spin">refresh</span> Cargando usuarios...
                                </div>
                            </div>

                        </div>

                        <div class="modal-overlay" id="modal-user">
                            <div class="modal-card">
                                <header class="modal-header">
                                    <h3 id="modal-user-title">Nuevo Empleado</h3>
                                    <button class="btn-close-modal" id="btn-close-user">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </header>

                                <div class="modal-body">
                                    <form id="form-user">
                                        <input type="hidden" id="user-id">

                                        <div class="form-grid">
                                            <div class="form-group full-width">
                                                <label>Nombre Completo</label>
                                                <input type="text" id="user-name" placeholder="Ej: Agustin Lezcano"
                                                    required minlength="2">
                                            </div>

                                            <div class="form-group full-width">
                                                <label>Correo Electrónico (Email para login)</label>
                                                <input type="email" id="user-email" placeholder="ejemplo@soldemayo.com"
                                                    required>
                                            </div>

                                            <div class="form-group full-width">
                                                <label>Sucursal Asignada</label>
                                                <select id="user-branch" required>
                                                    <option value="" disabled selected>Seleccionar sucursal...</option>
                                                </select>
                                            </div>

                                            <div class="form-group" id="group-initial-password">
                                                <label>Contraseña</label>
                                                <input type="password" id="user-password"
                                                    placeholder="Mínimo 6 caracteres">
                                            </div>
                                            <div class="form-group" id="group-confirm-password">
                                                <label>Confirmar Contraseña</label>
                                                <input type="password" id="user-confirm-password"
                                                    placeholder="Repetir contraseña">
                                                <span id="create-password-error"
                                                    style="color: #ef4444; font-size: 0.8rem; display: none; margin-top: 4px;">Las
                                                    contraseñas no coinciden.</span>
                                            </div>
                                        </div>
                                    </form>
                                </div>

                                <div class="modal-actions">
                                    <button class="btn-cancel" id="btn-cancel-user">Cancelar</button>
                                    <button class="btn-primary" id="btn-save-user" type="button" onclick="saveUser()">
                                        <span class="material-symbols-outlined">save</span> <span
                                            id="btn-save-user-text">Crear Usuario</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="modal-overlay" id="modal-password">
                            <div class="modal-card modal-small">
                                <header class="modal-header">
                                    <h3>Resetear Contraseña</h3>
                                    <button class="btn-close-modal" id="btn-close-password">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </header>

                                <div class="modal-body">
                                    <p class="text-muted" style="margin-bottom: 1rem; font-size: 0.9rem;">
                                        Estás por forzar el cambio de contraseña del usuario <strong
                                            id="reset-user-name" style="color: var(--text-primary);">Usuario</strong>.
                                    </p>
                                    <form id="form-password">
                                        <input type="hidden" id="reset-user-id">
                                        <div class="form-group">
                                            <label>Nueva Contraseña Temporal</label>
                                            <input type="password" id="new-password" placeholder="Mínimo 6 caracteres"
                                                required minlength="6">
                                        </div>
                                        <div class="form-group" style="margin-top: 1rem;">
                                            <label>Confirmar Contraseña Temporal</label>
                                            <input type="password" id="confirm-password"
                                                placeholder="Repetir contraseña" required minlength="6">
                                            <span id="password-error"
                                                style="color: #ef4444; font-size: 0.8rem; display: none; margin-top: 4px;">Las
                                                contraseñas no coinciden.</span>
                                        </div>
                                    </form>
                                </div>

                                <div class="modal-actions">
                                    <button class="btn-cancel" id="btn-cancel-password">Cancelar</button>
                                    <button class="btn-danger" id="btn-confirm-reset" type="button"
                                        onclick="resetUserPassword()">
                                        <span class="material-symbols-outlined">key</span> Resetear
                                    </button>
                                </div>
                            </div>
                        </div>

                </main>
        </div>
    </body>

</html>
