<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Sucursales' , cssFile: 'branches.css' }) %>

    <body>
        <div class="layout">
            <%- include('../partials/sidebar', { activePage: 'branches' }) %>

                <main class="layout__content">
                    <%- include('../partials/navbar', { title: 'Sucursales' }) %>

                        <div class="main-container">
                            <div class="branches-toolbar">
                                <button class="btn-primary" onclick="abrirModalNuevaSucursal()">
                                    <span class="material-symbols-outlined">add</span> Nueva Sucursal
                                </button>
                            </div>

                            <div class="branches-grid" id="branches-list-container">
                                <div
                                    style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--text-muted);">
                                    <span class="material-symbols-outlined spin">refresh</span> Cargando sucursales...
                                </div>
                            </div>
                        </div>

                        <div class="modal-overlay" id="modal-branch">
                            <div class="modal-card">
                                <header class="modal-header">
                                    <h3 id="modal-branch-title">Nueva Sucursal</h3>
                                    <button class="btn-close-modal" id="btn-close-branch">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </header>

                                <div class="modal-body">
                                    <form id="form-branch">
                                        <input type="hidden" id="branch-id">

                                        <div class="form-grid">
                                            <div class="form-group full-width">
                                                <label>Nombre de la Sucursal</label>
                                                <input type="text" id="branch-name" placeholder="Ej: Sucursal Centro"
                                                    required minlength="3">
                                            </div>

                                            <div class="form-group full-width">
                                                <label>Dirección</label>
                                                <input type="text" id="branch-address" placeholder="Ej: San Martín 123"
                                                    required minlength="4">
                                            </div>

                                            <div class="form-group">
                                                <label>Provincia</label>
                                                <select id="branch-province" required>
                                                    <option value="" disabled selected>Cargando provincias...</option>
                                                </select>
                                            </div>

                                            <div class="form-group">
                                                <label>Localidad / Ciudad</label>
                                                <select id="branch-city" required disabled>
                                                    <option value="" disabled selected>Seleccionar provincia primero...
                                                    </option>
                                                </select>
                                            </div>

                                            <div class="form-group full-width">
                                                <label>Tipo de Sucursal</label>
                                                <select id="branch-type" required>
                                                    <option value="" disabled selected>Cargando tipos...</option>
                                                </select>
                                            </div>
                                        </div>
                                    </form>
                                </div>

                                <div class="modal-actions">
                                    <button class="btn-cancel" id="btn-cancel-branch">Cancelar</button>
                                    <button class="btn-primary" id="btn-save-branch" type="button">
                                        <span class="material-symbols-outlined">save</span>
                                        <span id="btn-save-text">Crear Sucursal</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <script src="/js/branches.js"></script>
                </main>
        </div>
    </body>

</html>