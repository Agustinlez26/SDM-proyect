<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    
    <link rel="stylesheet" href="/css/partials/base.css?v=2.0">
    <link rel="stylesheet" href="/css/partials/sidebar.css?v=2.0">
    <link rel="stylesheet" href="/css/partials/navbar.css?v=2.0">
    <link rel="icon" type="image/png" href="/imgs/favicon.png?v=1.0">

    <script src="/socket.io/socket.io.js"></script>
    
    <!-- Render-blocking theme check to prevent FOUC (Flash of unstyled content) -->
    <script>
        (function() {
            try {
                if (localStorage.getItem('theme') === 'dark') {
                    document.documentElement.classList.add('dark-theme');
                }
            } catch(e) {}
        })();
    </script>

    <% if (!locals.excludeBaseJs) { %>
        <script src="/js/base.js?v=2.0" defer></script>
    <% } %>

    <% if (typeof cssFile !== 'undefined' ) { %>
        <link rel="stylesheet" href="/css/<%= cssFile %>?v=2.0">
    <% } %>

    <% if (typeof extraCss !== 'undefined' && Array.isArray(extraCss)) { %>
        <% extraCss.forEach(function(cssPath) { %>
            <link rel="stylesheet" href="<%= cssPath %>?v=2.0">
        <% }) %>
    <% } %>

    <% if (locals.jsFile) { %>
        <script src="/js/<%= jsFile %>?v=2.0" defer></script>
    <% } %>
    
    <title><%= title %></title>
</head>
