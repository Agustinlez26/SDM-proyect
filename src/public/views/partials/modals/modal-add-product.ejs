<div class="modal-overlay" id="modal-add-product">
    <div class="modal-card">
        <header class="modal-header">
            <h3 id="product-modal-title">Añade un producto</h3>
            <button class="btn-close-modal" data-target="modal-add-product">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form class="modal-form" id="form-product">
            <input type="hidden" id="prod-id">
            <input type="hidden" id="prod-is-active" value="1">

            <div class="modal-form-grid">
                <div class="modal-text-col">
                    <div class="form-group">
                        <label>Nombre del Producto</label>
                        <input type="text" id="prod-name" placeholder="Ej: Coca Cola 2.25L" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Código de Barras</label>
                            <input type="text" id="prod-code" placeholder="Ej: 779123456789" required>
                        </div>
                        <div class="form-group">
                            <label>Categoría</label>
                            <select id="prod-category" required>
                                <option value="" disabled selected>Seleccionar...</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Descripción</label>
                        <textarea id="prod-desc" rows="4" placeholder="Detalles del producto..." required></textarea>
                    </div>
                </div>

                <div class="modal-image-col">
                    <div>
                        <label>Imagen Actual / Vista Previa</label>
                        <div class="preview-img-container">
                            <img id="prod-img-preview" src="" alt="">
                        </div>
                    </div>

                    <div>
                        <label>Cambiar Imagen</label>
                        <input type="file" id="prod-img" name="image" accept="image/*">
                    </div>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-cancel" data-target="modal-add-product">Cancelar</button>
                <button type="submit" class="btn-confirm" id="btn-save-product">Guardar Producto</button>
            </div>
        </form>
    </div>
</div>